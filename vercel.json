{
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/now-playing",
      "dest": "/api/now-playing.js"
    },
    {
      "src": "/api/app-icon",
      "dest": "/api/app-icon.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}